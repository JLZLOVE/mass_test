<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="untiy.mapper.SysMajorMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="untiy.entity.SysMajor">
        <id column="id" property="id" />
        <result column="major_name" property="majorName" />
        <result column="major_code" property="majorCode" />
        <result column="college_id" property="collegeId" />
        <result column="head_teacher_id" property="headTeacherId" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, major_name, major_code, college_id, head_teacher_id, status, create_time
    </sql>

</mapper>
