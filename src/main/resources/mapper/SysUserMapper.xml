<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="untiy.mapper.SysUserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="untiy.entity.SysUser">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="real_name" property="realName" />
        <result column="gender" property="gender" />
        <result column="phone" property="phone" />
        <result column="email" property="email" />
        <result column="avatar" property="avatar" />
        <result column="user_type" property="userType" />
        <result column="student_no" property="studentNo" />
        <result column="teacher_no" property="teacherNo" />
        <result column="id_card" property="idCard" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, username, password, real_name, gender, phone, email, avatar, user_type, student_no, teacher_no, id_card, status, create_time, update_time
    </sql>

    <select id="selectByStatusId" resultType="untiy.entity.view.SysUserView">
        select * from sys_user where username = #{nameId}
    </select>

    <select id="selectByUsername" resultType="untiy.entity.SysUser">
        select *
        from sys_user
        where username = #{username}
    </select>

    <delete id="deleteByUsername">
        delete from sys_user
        where username = #{username}
    </delete>

    <delete id="deleteByUsernames">
        delete from sys_user
        where username in
        <foreach collection="usernames" item="username" open="(" separator="," close=")">
            #{username}
        </foreach>
    </delete>
</mapper>
