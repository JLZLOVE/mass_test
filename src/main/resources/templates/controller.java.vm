package untiy.controller;

## 定义实体变量名（首字母小写）
#set($entityPropertyName = $entity.substring(0,1).toLowerCase() + $entity.substring(1))
## 定义泛型字符串变量，避免尖括号被Velocity解析
#set($Entity = ${entity})
#set($QueryWrapperEntity = "QueryWrapper<${Entity}>")
#set($ListEntity = "List<${Entity}>")
#set($IPageEntity = "IPage<${Entity}>")
#set($PageEntity = "Page<${Entity}>")

import com.baomidou.mybatisplus.core.conditions.query.QueryWrapper;
import com.baomidou.mybatisplus.core.metadata.IPage;
import com.baomidou.mybatisplus.extension.plugins.pagination.Page;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import untiy.entity.${entity};
import untiy.service.${entity}Service;
import untiy.utils.MPUtil;
import untiy.utils.R;
import untiy.annotion.IgnoreAuth;   // 注意：这里是 annotion，不是 annotation

import javax.validation.Valid;
import java.util.List;
import java.util.Map;

#if(${restControllerStyle})
import org.springframework.web.bind.annotation.RestController;
#else
import org.springframework.stereotype.Controller;
#end

/**
 * <p>
 * $!{table.comment} 前端控制器
 * </p>
 *
 * @author ${author}
 * @since ${date}
 */
#if(${restControllerStyle})
@RestController
#else
@Controller
#end
#set($hyphenPath = $table.entityPath.replaceAll("([a-z])([A-Z])", "$1-$2").toLowerCase())
@RequestMapping("/${hyphenPath}")
public class ${entity}Controller {

    @Autowired
    private ${entity}Service ${entityPropertyName}Service;

    /**
     * 列表查询（后端）
     */
    @GetMapping("/list${entity}")
    public R list${entity}() {
        $QueryWrapperEntity ew = new QueryWrapper<>();
        $ListEntity list = ${entityPropertyName}Service.list(ew);
        return R.ok().put("data", list);
    }

    /**
     * 前端查询（公开）
     */
    @IgnoreAuth
    @GetMapping("/list${entity}_F")
    public R list${entity}_F(@RequestParam Map<String, Object> param, ${entity} ${entityPropertyName}) {
        $QueryWrapperEntity queryWrapper = new QueryWrapper<>();
        MPUtil.likeOrEq(queryWrapper, ${entityPropertyName});
        MPUtil.between(queryWrapper, param);
        MPUtil.sort(queryWrapper, param);
        $PageEntity page = MPUtil.getPage(param);
        $IPageEntity page1 = ${entityPropertyName}Service.page(page, queryWrapper);
        return R.ok().put("data", page1);
    }

    /**
     * 后端查询（需鉴权）
     */
    @GetMapping("/list${entity}_B")
    public R list${entity}_B(@RequestParam Map<String, Object> param, ${entity} ${entityPropertyName}) {
        $PageEntity page = MPUtil.getPage(param);
        $IPageEntity page1 = ${entityPropertyName}Service.page(page, MPUtil.sort(
                MPUtil.between(
                        MPUtil.likeOrEq(new QueryWrapper<>(), ${entityPropertyName}),
                        param
                ),
                param
        ));
        return R.ok().put("data", page1);
    }

    /**
     * 公开条件查询
     */
    @GetMapping("/query")
    public R query(${entity} ${entityPropertyName}) {
        $QueryWrapperEntity queryWrapper = new QueryWrapper<>();
        $ListEntity list = ${entityPropertyName}Service.list(MPUtil.likeOrEq(queryWrapper, ${entityPropertyName}));
        return R.ok().put("data", list);
    }

    /**
     * 单个后端查询
     */
    @GetMapping("/detail${entity}_B/{id}")
    public R detail${entity}_B(@PathVariable("id") Long id) {
        ${entity} obj = ${entityPropertyName}Service.getById(id);
        return R.ok().put("data", obj);
    }

    /**
     * 单个前端查询（公开）
     */
    @IgnoreAuth
    @GetMapping("/detail${entity}_F/{id}")
    public R detail${entity}_F(@PathVariable("id") Long id) {
        ${entity} obj = ${entityPropertyName}Service.getById(id);
        return R.ok().put("data", obj);
    }

    /**
     * 后端增加
     */
    @PostMapping("/add_B")
    public R add_B(@Valid @RequestBody ${entity} ${entityPropertyName}) {
            ${entityPropertyName}Service.save(${entityPropertyName});
        return R.ok("添加成功").put("data", ${entityPropertyName});
    }

    /**
     * 前端增加（公开）
     */
    @IgnoreAuth
    @PostMapping("/add_F")
    public R add_F(@Valid @RequestBody ${entity} ${entityPropertyName}) {
            ${entityPropertyName}Service.save(${entityPropertyName});
        return R.ok("添加成功").put("data", ${entityPropertyName});
    }

    /**
     * 后端批量更新
     */
    @PutMapping("/update${entity}_B")
    public R update${entity}_B(@Valid @RequestBody $ListEntity ${entityPropertyName}s) {
            ${entityPropertyName}Service.updateBatchById(${entityPropertyName}s);
        return R.ok();
    }

    /**
     * 前端单个更新（公开）
     */
    @IgnoreAuth
    @PutMapping("/update${entity}_F")
    public R update${entity}_F(@Valid @RequestBody ${entity} ${entityPropertyName}) {
            ${entityPropertyName}Service.updateById(${entityPropertyName});
        return R.ok();
    }

    /**
     * 后端批量删除
     */
    @DeleteMapping("/delete${entity}_B")
    public R delete${entity}_B(@RequestBody List<Long> ids) {
            ${entityPropertyName}Service.removeByIds(ids);
        return R.ok();
    }

    /**
     * 前端单个删除（公开）
     */
    @DeleteMapping("/delete${entity}_F/{id}")
    public R delete${entity}_F(@PathVariable Long id) {
            ${entityPropertyName}Service.removeById(id);
        return R.ok();
    }
}